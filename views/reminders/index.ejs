<%- include('../partials/header') %>
<h1 class="mb-4">Reminders</h1>
<% const sections = [
  { key: 'water', label: 'Watering', icon: '💧' },
  { key: 'feed',  label: 'Feeding',  icon: '🌿' },
  { key: 'weed',  label: 'Weeding',  icon: '🌾' },
  { key: 'prune', label: 'Pruning',  icon: '✂️' }
]; %>
<div class="row g-3">
<% sections.forEach(section => { %>
  <div class="col-md-6">
    <div class="card shadow-sm h-100">
      <div class="card-header fw-bold"><%= section.icon %> <%= section.label %></div>
      <div class="card-body">
        <% if (grouped[section.key].length === 0) { %>
          <p class="text-muted mb-0">No <%= section.label.toLowerCase() %> reminders.</p>
        <% } else { %>
        <ul class="list-group list-group-flush">
          <% grouped[section.key].forEach(r => { %>
            <li class="list-group-item px-0">
              <strong><%= r.plantName %></strong>
              <span class="badge bg-success ms-2">Due: <%= r.dueDate %></span>
              <small class="text-muted d-block">Every <%= r.frequency %> days</small>
            </li>
          <% }) %>
        </ul>
        <% } %>
      </div>
    </div>
  </div>
<% }) %>
</div>
<%- include('../partials/footer') %>
