<%- include('partials/header') %>
<section class="page-hero">
  <p class="eyebrow">Season Planner</p>
  <h1>Grow Smarter, From Seed To Harvest</h1>
  <p class="hero-copy">Track every plant, save scientific details, and keep your care tasks clear with a dashboard designed for real gardeners.</p>
  <div class="hero-actions">
    <a class="btn" href="/plants/add">Add a Plant</a>
    <a class="btn btn-secondary" href="/plants">View Collection</a>
  </div>
</section>

<section class="cards metrics">
  <article class="card spotlight">
    <h2>Plants In Collection</h2>
    <p class="count"><%= plantCount %></p>
    <p>See complete records with common names, scientific names, genus, and family.</p>
    <a href="/plants">Open Plants</a>
  </article>

  <article class="card spotlight">
    <h2>Active Reminders</h2>
    <p class="count"><%= reminderCount %></p>
    <p>Watering, feeding, weeding, and pruning schedules in one place.</p>
    <a href="/reminders">Open Reminders</a>
  </article>
</section>
<h1 class="mb-4">Welcome to Garden Manager</h1>
<div class="row g-3">
  <div class="col-sm-6">
    <div class="card h-100 text-center shadow-sm">
      <div class="card-body">
        <h2 class="card-title h4">Plants</h2>
        <p class="display-4 fw-bold gm-count my-3"><%= plantCount %></p>
        <a href="/plants" class="btn btn-success">View Plants</a>
      </div>
    </div>
  </div>
  <div class="col-sm-6">
    <div class="card h-100 text-center shadow-sm">
      <div class="card-body">
        <h2 class="card-title h4">Reminders</h2>
        <p class="display-4 fw-bold gm-count my-3"><%= reminderCount %></p>
        <a href="/reminders" class="btn btn-success">View Reminders</a>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
