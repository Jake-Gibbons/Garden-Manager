<%- include('partials/header') %>
<section class="page-hero animate-in">
  <p class="eyebrow">🌱 Garden Manager</p>
  <h1>Your Garden, Beautifully Organised</h1>
  <p class="hero-copy">Track every plant, plan your beds, and stay on top of watering, feeding, and pruning — all in one calm, clear place.</p>
  <div class="hero-grid">
    <article class="hero-stat-card">
      <p>Tracked plants</p>
      <strong><%= plantCount %></strong>
    </article>
    <article class="hero-stat-card">
      <p>Active reminders</p>
      <strong><%= reminderCount %></strong>
    </article>
    <article class="hero-stat-card">
      <p>Next step</p>
      <strong><%= plantCount > 0 ? 'Check reminders' : 'Add first plant' %></strong>
    </article>
  </div>
  <div class="hero-actions">
    <a class="btn" href="/plants/add">+ Add a Plant</a>
    <a class="btn btn-secondary" href="/plants">View Collection</a>
    <a class="btn btn-secondary" href="/plant-database">Browse 159 Plants</a>
  </div>
</section>

<section class="tri-grid animate-in-delay-1">
  <article class="card workflow-card">
    <p class="eyebrow">01</p>
    <h2>Plan Your Garden</h2>
    <p>Draw your plot, place plant markers, and map out growing zones with the interactive garden planner.</p>
    <a href="/garden-plan">Open Planner →</a>
  </article>

  <article class="card workflow-card">
    <p class="eyebrow">02</p>
    <h2>Track Every Plant</h2>
    <p>Build a clear collection of all your plants — from species info and soil preferences to toxicity notes.</p>
    <a href="/plants">Open Collection →</a>
  </article>

  <article class="card workflow-card">
    <p class="eyebrow">03</p>
    <h2>Stay On Schedule</h2>
    <p>Smart reminders keep watering, feeding, weeding, and pruning on track — list view or calendar view.</p>
    <a href="/reminders">Open Reminders →</a>
  </article>
</section>

<section class="dual-grid animate-in-delay-2">
  <article class="card">
    <p class="eyebrow">Reference Library</p>
    <h2>159 Plants Ready to Browse</h2>
    <p>Comprehensive species data for vegetables, herbs, flowers, fruits, trees, shrubs, houseplants, succulents, and more. Tap any plant to prefill your collection instantly.</p>
    <div style="margin-top:1rem">
      <a href="/plant-database" class="btn">Browse Plant Database →</a>
    </div>
  </article>
  <article class="card">
    <p class="eyebrow">GBIF Lookup</p>
    <h2>Scientific Name Lookup</h2>
    <p>Not sure of a plant's full taxonomy? Use the built-in GBIF species search to find accurate genus, family, and scientific names before adding a profile.</p>
    <div style="margin-top:1rem">
      <a href="/plants/add" class="btn btn-secondary">Add Plant with Lookup →</a>
    </div>
  </article>
</section>
<%- include('partials/footer') %>
