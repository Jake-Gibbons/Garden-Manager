<%- include('../partials/header') %>
<section class="page-hero compact">
  <p class="eyebrow">Reference Library</p>
  <h1>Plant Database</h1>
  <p>Find credible species information quickly, then jump into full detail only when needed.</p>
</section>

<section class="panel database-controls">
  <form method="GET" action="/plant-database" id="databaseFiltersForm" class="form-grid three-col">
    <div class="form-group">
      <label for="dbSearch">Search</label>
      <input id="dbSearch" name="search" type="text" value="<%= filters.search %>" placeholder="Search by common/scientific name, family, or genus">
    </div>
    <div class="form-group">
      <label for="dbType">Type</label>
      <select id="dbType" name="type">
        <option value="all" <%= filters.type === 'all' ? 'selected' : '' %>>All Types</option>
        <% typeOptions.forEach((option) => { %>
          <option value="<%= option.value %>" <%= filters.type === option.value ? 'selected' : '' %>><%= option.label %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label for="dbSunlight">Sunlight</label>
      <select id="dbSunlight" name="sunlight">
        <option value="all" <%= filters.sunlight === 'all' ? 'selected' : '' %>>All</option>
        <option value="full" <%= filters.sunlight === 'full' ? 'selected' : '' %>>Full</option>
        <option value="partial" <%= filters.sunlight === 'partial' ? 'selected' : '' %>>Partial</option>
        <option value="shady" <%= filters.sunlight === 'shady' ? 'selected' : '' %>>Shady</option>
      </select>
    </div>
    <div class="database-filter-actions">
      <button type="submit" class="btn">Apply Filters</button>
      <a href="/plant-database" class="btn btn-secondary" id="clearDatabaseFilters">Clear</a>
    </div>
  </form>
  <p class="database-summary"><strong><%= pagination.totalResults %></strong> results found. Showing page <strong><%= pagination.currentPage %></strong> of <strong><%= pagination.totalPages %></strong>.</p>
</section>

<section id="databaseCards" class="database-grid">
  <% plantDatabase.forEach((plant) => { %>
    <article class="panel database-card">
      <a href="/plant-database/<%= encodeURIComponent(plant.id) %>" class="database-card-media-link" aria-label="View details for <%= plant.commonName %>">
        <img class="database-card-image" src="<%= plant.image %>" alt="<%= plant.imageAlt %>">
      </a>
      <header class="database-card-head">
        <h2><%= plant.commonName %></h2>
        <p><em><%= plant.scientificName %></em></p>
      </header>
      <a class="btn btn-secondary" href="/plant-database/<%= encodeURIComponent(plant.id) %>">
        More Info
      </a>
    </article>
  <% }) %>
</section>

<% if (plantDatabase.length === 0) { %>
  <p id="databaseNoResults" class="panel empty-state">No plants match your filters.</p>
<% } %>

<% if (pagination.totalPages > 1) { %>
  <nav class="panel pagination-bar" aria-label="Plant database pagination">
    <% for (let page = 1; page <= pagination.totalPages; page += 1) { %>
      <a
        href="/plant-database?search=<%= encodeURIComponent(filters.search) %>&type=<%= encodeURIComponent(filters.type) %>&sunlight=<%= encodeURIComponent(filters.sunlight) %>&page=<%= page %>"
        class="btn <%= page === pagination.currentPage ? '' : 'btn-secondary' %>">
        <%= page %>
      </a>
    <% } %>
  </nav>
<% } %>

<script>
  const filtersForm = document.getElementById('databaseFiltersForm');
  const searchInput = document.getElementById('dbSearch');
  const typeSelect = document.getElementById('dbType');
  const sunlightSelect = document.getElementById('dbSunlight');
  const storageKey = 'garden-manager-plant-db-filters';

  function currentFilterState() {
    return {
      search: searchInput.value.trim(),
      type: typeSelect.value,
      sunlight: sunlightSelect.value
    };
  }

  function persistFilters() {
    localStorage.setItem(storageKey, JSON.stringify(currentFilterState()));
  }

  if (!window.location.search) {
    const saved = localStorage.getItem(storageKey);
    if (saved) {
      try {
        const parsed = JSON.parse(saved);
        const params = new URLSearchParams();
        if (parsed.search) params.set('search', parsed.search);
        if (parsed.type) params.set('type', parsed.type);
        if (parsed.sunlight) params.set('sunlight', parsed.sunlight);
        if (params.toString()) {
          window.location.replace(`/plant-database?${params.toString()}`);
        }
      } catch (error) {
        localStorage.removeItem(storageKey);
      }
    }
  }

  filtersForm.addEventListener('submit', persistFilters);
  typeSelect.addEventListener('change', persistFilters);
  sunlightSelect.addEventListener('change', persistFilters);
  searchInput.addEventListener('change', persistFilters);

  document.getElementById('clearDatabaseFilters').addEventListener('click', () => {
    localStorage.removeItem(storageKey);
  });
</script>
<%- include('../partials/footer') %>
