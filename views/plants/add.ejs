<%- include('../partials/header') %>
<% const catalog = Array.isArray(typeof plantCatalog === 'undefined' ? [] : plantCatalog) ? plantCatalog : []; %>
<% const selectedPlantId = typeof preselectedPlantId === 'string' ? preselectedPlantId : ''; %>
<section class="page-hero compact">
  <h1>Build Your Garden Profile</h1>
  <p>Choose a pre-loaded plant for instant taxonomy details, or enter your own species data manually.</p>
</section>

<section class="panel form-panel">
  <form method="POST" action="/plants/add" class="plant-form" id="add-plant-form">
    <div class="form-grid two-col">
      <div class="form-group">
        <label for="plantTemplate">Choose from common plants and vegetables</label>
        <select id="plantTemplate" name="plant_template">
          <option value="">Custom entry (no prefill)</option>
          <% catalog.forEach(plant => { %>
            <option value="<%= plant.id %>" <%= selectedPlantId === plant.id ? 'selected' : '' %>><%= plant.commonName %> - <%= plant.scientificName %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="type">Plant Type</label>
        <select id="type" name="type">
          <option value="vegetable">Vegetable</option>
          <option value="flower">Flower</option>
          <option value="herb">Herb</option>
          <option value="fruit">Fruit</option>
          <option value="other">Other</option>
        </select>
      </div>
    </div>

    <div id="taxonomyPreview" class="taxonomy-preview hidden" aria-live="polite">
      <h2>Selected Plant Taxonomy</h2>
      <p><strong>Common Name:</strong> <span id="previewCommonName">-</span></p>
      <p><strong>Scientific Name:</strong> <span id="previewScientificName">-</span></p>
      <p><strong>Genus:</strong> <span id="previewGenus">-</span></p>
      <p><strong>Family:</strong> <span id="previewFamily">-</span></p>
      <p><strong>Sunlight:</strong> <span id="previewSunlight">-</span></p>
      <p><strong>Soil:</strong> <span id="previewSoil">-</span></p>
      <p><strong>Common Pests/Diseases:</strong> <span id="previewPests">-</span></p>
      <p><strong>Toxicity/Harm:</strong> <span id="previewToxicity">-</span></p>
    </div>

    <div class="form-grid two-col">
      <div class="form-group">
        <label for="common_name">Common Name</label>
        <input type="text" id="common_name" name="common_name" required>
      </div>

      <div class="form-group">
        <label for="scientific_name">Scientific Name</label>
        <input type="text" id="scientific_name" name="scientific_name" required>
      </div>
    </div>

    <div class="form-grid two-col">
      <div class="form-group">
        <label for="genus">Genus</label>
        <input type="text" id="genus" name="genus">
      </div>

      <div class="form-group">
        <label for="family">Family</label>
        <input type="text" id="family" name="family">
      </div>
    </div>

    <div class="form-grid two-col">
      <div class="form-group">
        <label for="name">Display Name (optional)</label>
        <input type="text" id="name" name="name" placeholder="Example: Patio Tomato #1">
      </div>

      <div class="form-group">
        <label for="cultivation">Cultivation</label>
        <select id="cultivation" name="cultivation">
          <option value="outdoor">Outdoor</option>
          <option value="indoor">Indoor</option>
          <option value="greenhouse">Greenhouse</option>
          <option value="other">Other</option>
        </select>
      </div>
    </div>

    <div class="form-grid two-col">
      <div class="form-group">
        <label for="sunlight_preference">Sunlight Preference</label>
        <select id="sunlight_preference" name="sunlight_preference">
          <option value="full">Full Sun</option>
          <option value="partial">Partial Sun</option>
          <option value="shady">Shady</option>
        </select>
      </div>

      <div class="form-group">
        <label for="soil_type">Soil Type</label>
        <input type="text" id="soil_type" name="soil_type" placeholder="Example: Sandy, well-draining">
      </div>
    </div>

    <div class="form-grid two-col">
      <div class="form-group">
        <label for="common_pests_diseases">Common Pests or Diseases</label>
        <textarea id="common_pests_diseases" name="common_pests_diseases" placeholder="Example: aphids, powdery mildew"></textarea>
      </div>

      <div class="form-group">
        <label for="toxicity">Toxicity or Harmful Properties</label>
        <textarea id="toxicity" name="toxicity" placeholder="Example: toxic to pets if ingested"></textarea>
      </div>
    </div>

    <div class="form-grid two-col">
      <div class="form-group">
        <label for="planting_date">Planting Date</label>
        <input type="date" id="planting_date" name="planting_date" required>
      </div>

      <div class="form-group">
        <label for="notes">Notes</label>
        <textarea id="notes" name="notes" placeholder="Light needs, watering habits, growth goals..."></textarea>
      </div>
    </div>

    <button type="submit" class="btn">Add Plant</button>
  </form>
</section>

<script>
  const catalogData = <%- JSON.stringify(catalog) %>;
  const lookup = new Map(catalogData.map((item) => [item.id, item]));

  const plantTemplate = document.getElementById('plantTemplate');
  const commonNameInput = document.getElementById('common_name');
  const scientificNameInput = document.getElementById('scientific_name');
  const genusInput = document.getElementById('genus');
  const familyInput = document.getElementById('family');
  const sunlightInput = document.getElementById('sunlight_preference');
  const soilInput = document.getElementById('soil_type');
  const pestsInput = document.getElementById('common_pests_diseases');
  const toxicityInput = document.getElementById('toxicity');
  const typeInput = document.getElementById('type');

  const preview = document.getElementById('taxonomyPreview');
  const previewCommon = document.getElementById('previewCommonName');
  const previewScientific = document.getElementById('previewScientificName');
  const previewGenus = document.getElementById('previewGenus');
  const previewFamily = document.getElementById('previewFamily');
  const previewSunlight = document.getElementById('previewSunlight');
  const previewSoil = document.getElementById('previewSoil');
  const previewPests = document.getElementById('previewPests');
  const previewToxicity = document.getElementById('previewToxicity');

  function setPreview(plant) {
    previewCommon.textContent = plant.commonName || '-';
    previewScientific.textContent = plant.scientificName || '-';
    previewGenus.textContent = plant.genus || '-';
    previewFamily.textContent = plant.family || '-';
    previewSunlight.textContent = plant.sunlightPreference || '-';
    previewSoil.textContent = plant.soilType || '-';
    previewPests.textContent = plant.commonPestsDiseases || '-';
    previewToxicity.textContent = plant.toxicity || '-';
  }

  plantTemplate.addEventListener('change', () => {
    const selected = lookup.get(plantTemplate.value);

    if (!selected) {
      preview.classList.add('hidden');
      return;
    }

    commonNameInput.value = selected.commonName;
    scientificNameInput.value = selected.scientificName;
    genusInput.value = selected.genus;
    familyInput.value = selected.family;
    sunlightInput.value = selected.sunlightPreference || 'full';
    soilInput.value = selected.soilType || '';
    pestsInput.value = selected.commonPestsDiseases || '';
    toxicityInput.value = selected.toxicity || '';
    typeInput.value = selected.type;

    setPreview(selected);
    preview.classList.remove('hidden');
  });

  if (plantTemplate.value) {
    plantTemplate.dispatchEvent(new Event('change'));
  }
<h1 class="mb-4">Add Plant</h1>
<div class="row g-4">
  <!-- Add-plant form -->
  <div class="col-12 col-md-7">
    <div class="card shadow-sm">
      <div class="card-body">
        <form method="POST" action="/plants/add">
          <div class="mb-3">
            <label for="name" class="form-label fw-bold">Name</label>
            <input type="text" class="form-control" id="name" name="name" required
                   placeholder="e.g. Cherry Tomato">
          </div>
          <div class="mb-3">
            <label for="type" class="form-label fw-bold">Type</label>
            <select class="form-select" id="type" name="type">
              <% plantTypeOptions.forEach(opt => { %>
                <option value="<%= opt.value %>"><%= opt.label %></option>
              <% }); %>
            </select>
          </div>
          <div class="mb-3">
            <label for="cultivation" class="form-label fw-bold">Cultivation</label>
            <select class="form-select" id="cultivation" name="cultivation">
              <option value="outdoor">Outdoor</option>
              <option value="indoor">Indoor</option>
              <option value="greenhouse">Greenhouse</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="mb-3">
            <label for="planting_date" class="form-label fw-bold">Planting Date</label>
            <input type="date" class="form-control" id="planting_date" name="planting_date" required>
          </div>
          <div class="mb-3">
            <label for="notes" class="form-label fw-bold">Notes</label>
            <textarea class="form-control" id="notes" name="notes" rows="3"
                      placeholder="Optional notes about this plant"></textarea>
          </div>
          <button type="submit" class="btn btn-success">Add Plant</button>
        </form>
      </div>
    </div>
  </div>

  <!-- GBIF species lookup panel -->
  <div class="col-12 col-md-5">
    <div class="card shadow-sm">
      <div class="card-header gm-thead text-white fw-bold">
        🔍 GBIF Species Lookup
      </div>
      <div class="card-body">
        <p class="small text-muted mb-2">
          Search the <a href="https://www.gbif.org" target="_blank" rel="noopener">
          Global Biodiversity Information Facility (GBIF)</a> checklist for
          scientific classification and taxonomy of your plant.
        </p>
        <div class="input-group mb-3">
          <input type="text" class="form-control" id="gbif-query"
                 placeholder="e.g. tomato, Rosa, apple">
          <button class="btn btn-outline-success" id="gbif-search-btn" type="button">Search</button>
        </div>
        <div id="gbif-results"></div>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  const searchBtn = document.getElementById('gbif-search-btn');
  const queryInput = document.getElementById('gbif-query');
  const resultsEl = document.getElementById('gbif-results');

  // Species data is stored in memory, keyed by a sequential index written
  // to each button's data-species-index attribute.  This avoids placing
  // arbitrary JSON inside an onclick attribute (XSS risk).
  const speciesCache = [];

  function escHtml(str) {
    if (typeof str !== 'string') return str;
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function renderOptionalField(label, value) {
    if (!value) return '';
    return `<div>${escHtml(label)}: <span class="text-success">${escHtml(value)}</span></div>`;
  }

  function renderResults(results) {
    if (!results.length) {
      resultsEl.innerHTML = '<p class="text-muted small">No species found. Try a different name.</p>';
      return;
    }
    speciesCache.length = 0; // clear previous search
    const items = results.map((r, idx) => {
      speciesCache.push(r);
      return `
        <div class="border rounded p-2 mb-2 small">
          <div class="fw-bold">${escHtml(r.canonicalName || r.scientificName)}</div>
          <div class="text-muted fst-italic">${escHtml(r.scientificName)}</div>
          ${renderOptionalField('Family', r.family)}
          ${renderOptionalField('Kingdom', r.kingdom)}
          <button type="button" class="btn btn-sm btn-outline-secondary mt-1 gbif-use-btn"
                  data-species-index="${idx}">
            Use this name
          </button>
        </div>`;
    }).join('');
    resultsEl.innerHTML = items;
  }

  function useSpecies(species) {
    const nameField = document.getElementById('name');
    if (nameField && species.canonicalName) {
      nameField.value = species.canonicalName;
    }
    const notesField = document.getElementById('notes');
    if (notesField) {
      const parts = [];
      if (species.scientificName) parts.push('Scientific name: ' + species.scientificName);
      if (species.family) parts.push('Family: ' + species.family);
      if (species.kingdom) parts.push('Kingdom: ' + species.kingdom);
      if (notesField.value) parts.unshift(notesField.value);
      notesField.value = parts.join('\n');
    }
  }

  // Use event delegation on the results container so we never need inline onclick handlers.
  resultsEl.addEventListener('click', function (e) {
    const btn = e.target.closest('.gbif-use-btn');
    if (!btn) return;
    const idx = parseInt(btn.dataset.speciesIndex, 10);
    if (!isNaN(idx) && speciesCache[idx]) {
      useSpecies(speciesCache[idx]);
    }
  });

  async function doSearch() {
    const q = queryInput.value.trim();
    if (!q) return;
    resultsEl.innerHTML = '<p class="text-muted small">Searching GBIF…</p>';
    try {
      const resp = await fetch('/plants/lookup?q=' + encodeURIComponent(q));
      const data = await resp.json();
      if (data.error) {
        resultsEl.innerHTML = `<p class="text-danger small">${escHtml(data.error)}</p>`;
      } else {
        renderResults(data.results || []);
      }
    } catch (e) {
      resultsEl.innerHTML = '<p class="text-danger small">Lookup failed. Check your connection.</p>';
    }
  }

  searchBtn.addEventListener('click', doSearch);
  queryInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); doSearch(); } });
}());
</script>
<%- include('../partials/footer') %>
