  </main>
  <footer class="site-footer">
    <p>&copy; 2026 Garden Manager</p>
    <p>Plan layout, plant intelligence, and care workflows in one place.</p>
  </footer>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const currentPath = window.location.pathname;
    document.querySelectorAll('[data-nav-item]').forEach((link) => {
      const navPath = link.getAttribute('data-nav-item');
      const isRoot = navPath === '/';
      const isActive = isRoot ? currentPath === '/' : currentPath.startsWith(navPath);
      if (isActive) {
        link.classList.add('is-active');
      }
    });

    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js')
          .catch(err => console.error('Service worker registration failed:', err));
      });
    }
  </script>
</body>
